# ===================================
# CONFIGURATION GOOGLE CALENDAR
# ===================================
# ID du calendrier Google (trouvable dans les paramètres de Google Calendar)
GOOGLE_CALENDAR_ID=votre-email@gmail.com

# Chemin vers le fichier de credentials Google (service account)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# ===================================
# CONFIGURATION WHATSAPP BUSINESS API
# ===================================
# Token d'accès permanent WhatsApp Business (Meta Developer Console)
WHATSAPP_ACCESS_TOKEN=votre_token_whatsapp

# Numéro de téléphone ID (Meta Business Suite)
WHATSAPP_PHONE_NUMBER_ID=votre_phone_number_id

# ID du groupe WhatsApp (pour les notifications d'équipe)
WHATSAPP_GROUP_ID=votre_group_id

# Numéro du client pour confirmation individuelle (format: 213XXXXXXXXX)
# Laissez vide - sera rempli dynamiquement depuis le RDV
# WHATSAPP_CLIENT_NUMBER=

# ===================================
# CONFIGURATION DU WEBHOOK
# ===================================
# URL publique de votre Cloud Function (remplie après déploiement)
WEBHOOK_URL=https://votre-region-votre-projet.cloudfunctions.net/calendarWebhook

# Token de vérification pour sécuriser le webhook
WEBHOOK_VERIFY_TOKEN=votre_token_secret_personnalise

# ===================================
# CONFIGURATION OPTIONNELLE
# ===================================
# Fuseau horaire (par défaut: Africa/Algiers)
TIMEZONE=Africa/Algiers

# Langue des messages (fr, ar, en)
MESSAGE_LANG=fr
